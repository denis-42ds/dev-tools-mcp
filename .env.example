# .env.example — скопируйте в .env и заполните при необходимости
# Реальные значения НЕ хранятся в репозитории.
# Базовый сценарий работает без каких-либо переменных.

# ── Сервер ──────────────────────────────────────────────────────────────────
# Порт HTTP-сервера (default: 8000)
PORT=8000

# ── Сканирование (scan_tech_debt) ───────────────────────────────────────────
# Путь, монтируемый в контейнер как /workspace
# SCAN_PATH=./your-project

# ── (Optional) Расширенный режим ────────────────────────────────────────────
# Если вы хотите отправлять отчёты во внешние сервисы — добавьте ключи здесь.
# Базовый сценарий НЕ требует этих переменных.

# Пример интеграции с Linear (optional, не реализовано в базовой версии):
# LINEAR_API_KEY=your_linear_api_key_here

# Пример интеграции с Slack (optional):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
